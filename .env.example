# ===== LLM Provider API Keys =====
# Set the key for whichever provider(s) you want to use.
# Defaults in config/models.yaml use github/* models.

# GitHub Models (free with Copilot subscription):
GITHUB_TOKEN=ghp_your_token_here

# OpenAI (also used for DALL-E 3 sprite generation):
OPENAI_API_KEY=sk-your_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1  # override for OpenAI-compatible endpoints (Yi, vLLM, etc.)

# Anthropic (Claude models):
# ANTHROPIC_API_KEY=your_key_here

# DeepSeek:
# DEEPSEEK_API_KEY=your_key_here

# Moonshot / Kimi (China):
# MOONSHOT_API_KEY=your_key_here

# Alibaba DashScope / Qwen (China):
# DASHSCOPE_API_KEY=your_key_here

# Zhipu AI / GLM (China):
# ZHIPUAI_API_KEY=your_key_here

# Google Gemini:
# GOOGLE_API_KEY=your_key_here

# Mistral:
# MISTRAL_API_KEY=your_key_here

# ===== Sprite Generation =====
# Sprite generation provider: openai | stable_diffusion | stub
# SPRITE_PROVIDER=stub

# Stable Diffusion REST API (if SPRITE_PROVIDER=stable_diffusion):
# SD_API_URL=http://localhost:7860

# ===== Tier Model Overrides =====
# Override which model each tier uses (any litellm model ID):
# TIER1_MODEL=github/gpt-4.1
# TIER2_MODEL=github/gpt-4.1-mini
# TIER3_MODEL=github/gpt-4.1-mini
#
# Examples with Chinese providers:
# TIER1_MODEL=deepseek/deepseek-chat
# TIER2_MODEL=dashscope/qwen-plus
# TIER3_MODEL=moonshot/moonshot-v1-32k
