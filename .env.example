# GitHub Models (free with Copilot subscription):
GITHUB_TOKEN=ghp_your_token_here

# OpenAI (for DALL-E 3 sprite generation):
OPENAI_API_KEY=sk-your_key_here

# Anthropic (optional — for Claude models):
# ANTHROPIC_API_KEY=your_key_here

# Sprite generation provider: openai | stable_diffusion | stub
# SPRITE_PROVIDER=stub

# Stable Diffusion REST API (if SPRITE_PROVIDER=stable_diffusion):
# SD_API_URL=http://localhost:7860

# Tier model overrides (optional — defaults in config/models.yaml):
# TIER1_MODEL=github/gpt-4.1
# TIER2_MODEL=github/gpt-4.1-mini
# TIER3_MODEL=github/gpt-4.1-mini
